<UserControl x:Class="ConcurrentProgrammingApp.Views.ProblemiClassiciView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="#0d0f1a"
             Foreground="#eae8e1">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Orientation="Vertical" Spacing="24" Padding="0,0,0,24">
            <!-- Header -->
            <StackPanel>
                <TextBlock Text="CAPITOLO 3" FontFamily="JetBrains Mono, Courier New" 
                           FontSize="11" Foreground="#00aaff" FontWeight="Bold" LetterSpacing="1" Margin="0,0,0,8"/>
                <TextBlock Text="Problemi Classici" FontFamily="JetBrains Mono, Courier New" 
                           FontSize="28" FontWeight="Bold" Foreground="#eae8e1"/>
                <TextBlock Text="Lettori-Scrittori, Dining Philosophers" 
                           FontSize="13" Foreground="#cccccc" Margin="0,8,0,0"/>
            </StackPanel>

            <!-- Readers-Writers -->
            <StackPanel Spacing="12">
                <TextBlock Text="Problema Lettori-Scrittori" FontFamily="JetBrains Mono, Courier New" 
                           FontSize="16" FontWeight="Bold" Foreground="#eae8e1"/>
                
                <Border Background="#1a1d28" BorderBrush="#00aaff" BorderThickness="0,0,0,3" Padding="16">
                    <TextBlock Text="Permette a più lettori di accedere contemporaneamente a una risorsa condivisa, ma garantisce l'accesso esclusivo agli scrittori. Uno scrittore deve attendere che tutti i lettori abbiano terminato." 
                               FontSize="12" Foreground="#cccccc" LineHeight="18" TextWrapping="Wrap"/>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.ColumnSpacing>12</Grid.ColumnSpacing>

                    <Border Grid.Column="0" Background="#1a1d28" BorderBrush="#383d4a" BorderThickness="1" CornerRadius="4" Padding="12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Lettori (Readers)" FontFamily="JetBrains Mono, Courier New" 
                                       FontSize="12" FontWeight="Bold" Foreground="#00aaff"/>
                            <TextBlock Text="• Possono leggere contemporaneamente" FontSize="11" Foreground="#cccccc"/>
                            <TextBlock Text="• Non modificano la risorsa" FontSize="11" Foreground="#cccccc"/>
                            <TextBlock Text="• Attendono solo se uno scrittore è attivo" FontSize="11" Foreground="#cccccc"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="#1a1d28" BorderBrush="#383d4a" BorderThickness="1" CornerRadius="4" Padding="12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Scrittori (Writers)" FontFamily="JetBrains Mono, Courier New" 
                                       FontSize="12" FontWeight="Bold" Foreground="#ffb347"/>
                            <TextBlock Text="• Richiedono accesso esclusivo" FontSize="11" Foreground="#cccccc"/>
                            <TextBlock Text="• Attendono che tutti i lettori terminino" FontSize="11" Foreground="#cccccc"/>
                            <TextBlock Text="• Possono causare starvation dei lettori" FontSize="11" Foreground="#cccccc"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>

            <!-- Dining Philosophers -->
            <StackPanel Spacing="12">
                <TextBlock Text="Filosofi a Cena" FontFamily="JetBrains Mono, Courier New" 
                           FontSize="16" FontWeight="Bold" Foreground="#eae8e1"/>
                
                <Border Background="#1a1d28" BorderBrush="#ff5555" BorderThickness="0,0,0,3" Padding="16">
                    <TextBlock Text="Cinque filosofi siedono attorno a un tavolo. Tra ogni coppia c'è una forchetta (5 in totale). Per mangiare, un filosofo deve prendere le due forchette adiacenti. Illustra la necessità di evitare deadlock e starvation." 
                               FontSize="12" Foreground="#cccccc" LineHeight="18" TextWrapping="Wrap"/>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.ColumnSpacing>8</Grid.ColumnSpacing>

                    <Border Grid.Column="0" Background="#1a1d28" BorderBrush="#383d4a" BorderThickness="1" CornerRadius="4" Padding="12">
                        <StackPanel Spacing="4" TextAlignment="Center">
                            <TextBlock Text="Pensando" FontFamily="JetBrains Mono, Courier New" 
                                       FontSize="11" FontWeight="Bold" Foreground="#00ff88"/>
                            <TextBlock Text="Non occupa risorse" FontSize="10" Foreground="#999999"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="#1a1d28" BorderBrush="#383d4a" BorderThickness="1" CornerRadius="4" Padding="12">
                        <StackPanel Spacing="4" TextAlignment="Center">
                            <TextBlock Text="Affamato" FontFamily="JetBrains Mono, Courier New" 
                                       FontSize="11" FontWeight="Bold" Foreground="#ffb347"/>
                            <TextBlock Text="Tenta acquisizione" FontSize="10" Foreground="#999999"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="#1a1d28" BorderBrush="#383d4a" BorderThickness="1" CornerRadius="4" Padding="12">
                        <StackPanel Spacing="4" TextAlignment="Center">
                            <TextBlock Text="Mangiando" FontFamily="JetBrains Mono, Courier New" 
                                       FontSize="11" FontWeight="Bold" Foreground="#ff5555"/>
                            <TextBlock Text="Ha entrambe le forchette" FontSize="10" Foreground="#999999"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <TextBlock Text="Le quattro condizioni necessarie per il deadlock:" FontFamily="JetBrains Mono, Courier New" 
                           FontSize="12" FontWeight="Bold" Foreground="#eae8e1" Margin="0,12,0,8"/>

                <Border Background="#1a1d28" BorderBrush="#383d4a" BorderThickness="1" CornerRadius="4" Padding="12">
                    <StackPanel Spacing="6">
                        <TextBlock Text="1. Mutua Esclusione: Le forchette non possono essere condivise" FontSize="11" Foreground="#cccccc"/>
                        <TextBlock Text="2. Hold and Wait: I filosofi mantengono una forchetta mentre attendono l'altra" FontSize="11" Foreground="#cccccc"/>
                        <TextBlock Text="3. No Preemption: Le forchette non possono essere tolte" FontSize="11" Foreground="#cccccc"/>
                        <TextBlock Text="4. Circular Wait: Catena circolare di attesa tra i filosofi" FontSize="11" Foreground="#cccccc"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
