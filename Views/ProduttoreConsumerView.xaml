<UserControl x:Class="ConcurrentProgrammingApp.Views.ProduttoreConsumerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="#0d0f1a"
             Foreground="#eae8e1">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Orientation="Vertical" Spacing="24" Padding="0,0,0,24">
            <!-- Header -->
            <StackPanel>
                <TextBlock Text="CAPITOLO 2" FontFamily="JetBrains Mono, Courier New" 
                           FontSize="11" Foreground="#ffb347" FontWeight="Bold" LetterSpacing="1" Margin="0,0,0,8"/>
                <TextBlock Text="Produttore-Consumatore" FontFamily="JetBrains Mono, Courier New" 
                           FontSize="28" FontWeight="Bold" Foreground="#eae8e1"/>
                <TextBlock Text="Bounded-Buffer Problem — Buffer condiviso e sincronizzazione" 
                           FontSize="13" Foreground="#cccccc" Margin="0,8,0,0"/>
            </StackPanel>

            <!-- Definition -->
            <Border Background="#1a1d28" BorderBrush="#ffb347" BorderThickness="0,0,0,3" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="DEFINIZIONE" FontFamily="JetBrains Mono, Courier New" 
                               FontSize="11" FontWeight="Bold" Foreground="#ffb347"/>
                    <TextBlock Text="Il problema produttore-consumatore (Bounded-Buffer) è un classico scenario di sincronizzazione in cui uno o più produttori generano dati e li inseriscono in un buffer condiviso a dimensione finita, mentre uno o più consumatori prelevano tali dati per elaborarli." 
                               FontSize="13" Foreground="#cccccc" LineHeight="20" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Interactive Simulation -->
            <StackPanel Spacing="12">
                <TextBlock Text="Simulazione Interattiva" FontFamily="JetBrains Mono, Courier New" 
                           FontSize="16" FontWeight="Bold" Foreground="#eae8e1"/>
                
                <Border Background="#1a1d28" BorderBrush="#383d4a" BorderThickness="1" CornerRadius="4" Padding="16">
                    <StackPanel Spacing="16">
                        <!-- Controls -->
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button x:Name="PlayButton" Content="▶ Play" Style="{StaticResource ButtonStyle}" 
                                    Click="PlayButton_Click" Padding="12,6" FontSize="12"/>
                            <Button x:Name="PauseButton" Content="⏸ Pausa" Style="{StaticResource ButtonStyle}" 
                                    Click="PauseButton_Click" Padding="12,6" FontSize="12" IsEnabled="False"/>
                            <Button x:Name="ResetButton" Content="↻ Reset" Background="#383d4a" Foreground="#999999"
                                    Click="ResetButton_Click" Padding="12,6" FontSize="12" BorderThickness="0" Cursor="Hand"/>
                        </StackPanel>

                        <!-- Semaphore Values -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.ColumnSpacing>12</Grid.ColumnSpacing>

                            <Border Grid.Column="0" Background="#1a1d28" BorderBrush="#383d4a" BorderThickness="1" CornerRadius="4" Padding="12">
                                <StackPanel Spacing="4" TextAlignment="Center">
                                    <TextBlock x:Name="MutexValue" Text="1" FontFamily="JetBrains Mono, Courier New" 
                                               FontSize="20" FontWeight="Bold" Foreground="#00ff88"/>
                                    <TextBlock Text="mutex" FontFamily="JetBrains Mono, Courier New" 
                                               FontSize="10" Foreground="#00ff88"/>
                                    <TextBlock Text="Mutua esclusione" FontSize="10" Foreground="#666666"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Background="#1a1d28" BorderBrush="#383d4a" BorderThickness="1" CornerRadius="4" Padding="12">
                                <StackPanel Spacing="4" TextAlignment="Center">
                                    <TextBlock x:Name="EmptyValue" Text="6" FontFamily="JetBrains Mono, Courier New" 
                                               FontSize="20" FontWeight="Bold" Foreground="#ffb347"/>
                                    <TextBlock Text="empty" FontFamily="JetBrains Mono, Courier New" 
                                               FontSize="10" Foreground="#ffb347"/>
                                    <TextBlock Text="Slot liberi" FontSize="10" Foreground="#666666"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Background="#1a1d28" BorderBrush="#383d4a" BorderThickness="1" CornerRadius="4" Padding="12">
                                <StackPanel Spacing="4" TextAlignment="Center">
                                    <TextBlock x:Name="FullValue" Text="0" FontFamily="JetBrains Mono, Courier New" 
                                               FontSize="20" FontWeight="Bold" Foreground="#00aaff"/>
                                    <TextBlock Text="full" FontFamily="JetBrains Mono, Courier New" 
                                               FontSize="10" Foreground="#00aaff"/>
                                    <TextBlock Text="Slot occupati" FontSize="10" Foreground="#666666"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Buffer Visualization -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="Buffer (6 slot)" FontFamily="JetBrains Mono, Courier New" 
                                       FontSize="11" Foreground="#666666"/>
                            <ItemsControl x:Name="BufferDisplay" Margin="0,4">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" Spacing="8"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Log -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Log di esecuzione" FontFamily="JetBrains Mono, Courier New" 
                                       FontSize="11" Foreground="#666666"/>
                            <Border Background="#0d0f1a" BorderBrush="#383d4a" BorderThickness="1" CornerRadius="4" 
                                    Height="120" Padding="8">
                                <TextBox x:Name="LogBox" Background="Transparent" Foreground="#00ff88" 
                                         BorderThickness="0" FontFamily="JetBrains Mono, Courier New" 
                                         FontSize="10" IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                                         Text="Simulazione pronta. Premi Play per avviare."/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Key Elements -->
            <StackPanel Spacing="12">
                <TextBlock Text="Elementi Chiave del Problema" FontFamily="JetBrains Mono, Courier New" 
                           FontSize="16" FontWeight="Bold" Foreground="#eae8e1"/>
                
                <Border Background="#1a1d28" BorderBrush="#383d4a" BorderThickness="1" CornerRadius="4" Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Buffer Condiviso" FontFamily="JetBrains Mono, Courier New" 
                                   FontSize="12" FontWeight="Bold" Foreground="#00ff88"/>
                        <TextBlock Text="Un'area di memoria con capacità limitata dove vengono depositati i dati." 
                                   FontSize="11" Foreground="#cccccc" LineHeight="16" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Background="#1a1d28" BorderBrush="#383d4a" BorderThickness="1" CornerRadius="4" Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Produttore" FontFamily="JetBrains Mono, Courier New" 
                                   FontSize="12" FontWeight="Bold" Foreground="#00ff88"/>
                        <TextBlock Text="Thread o processo che crea dati e li aggiunge al buffer. Non può inserire se il buffer è pieno." 
                                   FontSize="11" Foreground="#cccccc" LineHeight="16" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Background="#1a1d28" BorderBrush="#383d4a" BorderThickness="1" CornerRadius="4" Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Consumatore" FontFamily="JetBrains Mono, Courier New" 
                                   FontSize="12" FontWeight="Bold" Foreground="#00ff88"/>
                        <TextBlock Text="Thread o processo che preleva dati dal buffer. Non può prelevare se il buffer è vuoto." 
                                   FontSize="11" Foreground="#cccccc" LineHeight="16" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
