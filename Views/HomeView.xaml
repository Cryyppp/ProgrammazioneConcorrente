<UserControl x:Class="ConcurrentProgrammingApp.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="#0d0f1a"
             Foreground="#eae8e1">
    <StackPanel Orientation="Vertical" Spacing="24">
        <!-- Header -->
        <StackPanel>
            <TextBlock Text="INFORMATICA — SISTEMI OPERATIVI" FontFamily="JetBrains Mono, Courier New" 
                       FontSize="11" Foreground="#00ff88" FontWeight="Bold" LetterSpacing="1" Margin="0,0,0,8"/>
            <TextBlock Text="Programmazione" FontFamily="JetBrains Mono, Courier New" 
                       FontSize="32" FontWeight="Bold" Foreground="#eae8e1"/>
            <TextBlock Text="Concorrente" FontFamily="JetBrains Mono, Courier New" 
                       FontSize="32" FontWeight="Bold" Foreground="#00ff88"/>
            <TextBlock Text="Semafori &amp; Sincronizzazione" FontFamily="JetBrains Mono, Courier New" 
                       FontSize="14" Foreground="#ffb347" Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Description -->
        <TextBlock Text="Una guida completa ai meccanismi di sincronizzazione nei sistemi concorrenti: semafori, mutua esclusione, problemi classici e soluzioni per evitare deadlock e race conditions." 
                   FontSize="14" Foreground="#cccccc" LineHeight="22" TextWrapping="Wrap" MaxWidth="600"/>

        <!-- Stats -->
        <Grid Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.ColumnSpacing>32</Grid.ColumnSpacing>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                <TextBlock Text="3" FontFamily="JetBrains Mono, Courier New" FontSize="18" FontWeight="Bold" Foreground="#00ff88"/>
                <TextBlock Text="Tipi di Semafori" FontSize="12" Foreground="#999999" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                <TextBlock Text="3" FontFamily="JetBrains Mono, Courier New" FontSize="18" FontWeight="Bold" Foreground="#00ff88"/>
                <TextBlock Text="Problemi Classici" FontSize="12" Foreground="#999999" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12">
                <TextBlock Text="4+" FontFamily="JetBrains Mono, Courier New" FontSize="18" FontWeight="Bold" Foreground="#00ff88"/>
                <TextBlock Text="Meccanismi di Sync." FontSize="12" Foreground="#999999" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="12">
                <TextBlock Text="3" FontFamily="JetBrains Mono, Courier New" FontSize="18" FontWeight="Bold" Foreground="#00ff88"/>
                <TextBlock Text="Patologie Critiche" FontSize="12" Foreground="#999999" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Intro text -->
        <Border Background="#1a1d28" BorderBrush="#383d4a" BorderThickness="1" CornerRadius="4" Padding="20">
            <StackPanel Spacing="12">
                <TextBlock Text="Cos'è la Programmazione Concorrente?" FontFamily="JetBrains Mono, Courier New" 
                           FontSize="14" FontWeight="Bold" Foreground="#eae8e1"/>
                <TextBlock Text="La programmazione concorrente è un paradigma in cui più sequenze di istruzioni vengono eseguite contemporaneamente, condividendo risorse comuni. Questo approccio massimizza l'utilizzo delle risorse hardware moderne (CPU multi-core) ma introduce sfide critiche legate alla sincronizzazione e alla coordinazione tra processi o thread." 
                           FontSize="13" Foreground="#cccccc" LineHeight="20" TextWrapping="Wrap" Margin="0,0,0,12"/>
                <TextBlock Text="I meccanismi di sincronizzazione — come semafori, monitor e variabili di condizione — sono gli strumenti fondamentali per garantire la correttezza dei programmi concorrenti, evitando inconsistenze dei dati, stalli permanenti e comportamenti imprevedibili." 
                           FontSize="13" Foreground="#cccccc" LineHeight="20" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
